# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://vrodyamhdxrspnaxzdtg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (LLM extraction + embeddings)
OPENAI_API_KEY=your-openai-api-key

# Datalab (Chandra OCR 2)
DATALAB_API_KEY=your-datalab-api-key

# Pipeline (optional)
# PIPELINE_MODE=async enqueues OCR/analyze as background jobs on upload
# (processed by POST /api/jobs/run). Omit for the default client-driven flow.
PIPELINE_MODE=
# Bearer secret required by the job worker endpoint (POST /api/jobs/run).
# Vercel Cron sends CRON_SECRET automatically; either name works.
JOBS_RUNNER_SECRET=
