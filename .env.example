# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://vrodyamhdxrspnaxzdtg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (LLM extraction + embeddings)
OPENAI_API_KEY=your-openai-api-key

# Datalab (Chandra OCR 2)
DATALAB_API_KEY=your-datalab-api-key

# Pipeline (optional)
# OCR/analyze jobs run server-side by default and are drained after upload.
# Set PIPELINE_MODE=sync to disable the background queue for local debugging.
PIPELINE_MODE=
# Bearer secret required by the job worker endpoint (POST /api/jobs/run).
# Vercel Cron sends CRON_SECRET automatically; either name works.
JOBS_RUNNER_SECRET=

# Sentry (error monitoring + tracing)
# Create a project at https://sentry.io and copy the DSN.
# The public DSN goes to the browser; the server DSN is secret.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Auth token for source map uploads during build (create at Sentry → Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
